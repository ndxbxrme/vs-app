.nav-icon 
  display none
  width 25px
  height 30px
  transform rotate(0deg)
  transition .5s ease-in-out
  cursor pointer
  span
    background vs-grey
    display block
    position absolute
    height 2px
    width 100%
    opacity 1
    left 0
    transform rotate(0deg)
    transition .25s ease-in-out
    &:nth-child(1) 
      top 10px
    &:nth-child(2),
    &:nth-child(3) 
      top 18px
    &:nth-child(4) 
      top 26px
	&.open 
		span
			&:nth-child(1) 
				top 18px
				width 0%
				left 50%
			&:nth-child(2) 
				-webkit-transform rotate(45deg)
				-moz-transform rotate(45deg)
				-o-transform rotate(45deg)
				transform rotate(45deg)
			&:nth-child(3) 
				-webkit-transform rotate(-45deg)
				-moz-transform rotate(-45deg)
				-o-transform rotate(-45deg)
				transform rotate(-45deg)
			&:nth-child(4) 
				top 18px
				width 0%
				left 50%
.menu-controls
  display flex
  flex-direction row
  justify-content flex-end
.menu-col
  display flex
  flex-direction row
  align-items center
  .vs-logo
    max-width 220px
    margin-right 30px
.site-menu
  height 80px
  z-index 400
  position fixed
  top 0px
  left 0px
  background white
  width 100%
  height auto
  border-bottom 1px solid #e0e0e0
  sites
    display flex
    flex-direction row
    flex-wrap wrap
    &.site-settings
      justify-content flex-end
      site
        > a
          padding 0px 20px
          text-align right
          img 
            border-radius 50%
            width 40px
            height 40px
            margin-right 10px
            border 1px solid #e0e0e0
          &:hover
            color #f15b25
            background none
          svg
            padding 10px
        pages
          left auto
          right 0
          top 38px
          a
           text-align right 
  pages
    display none
    background white
  site
    display flex
    flex-direction column

    position relative
    justify-content center
    a
      color #303030
      font-size: 1.8rem
      font-weight 300
      padding 30px 20px
      text-transform capitalize
      transition all 0.4s ease-in-out
      text-align left
      font-weight 600
    a:hover, a:focus
      color #f15b25
    &:hover, &:focus
      pages
        display flex
        flex-direction column
        box-shadow 4px 4px 4px 0 rgba(0,0,0,.05)
        width 250px
        position absolute
        top 80px
        left 0
        border-radius 20px
        border 1px solid #e0e0e0
        padding 10px 0px
        a 
          padding 10px 20px
        a:hover, a:focus
          color #f15b25
          background rgba(0,0,0,0.05)
    .favorites-site
      font-size .8em
      margin-right .5em
.menu-profile
  display flex
  align-items center
@media screen and (max-width:1200px)
  .site-menu site a
    padding 30px 13px
@media screen and (max-width:992px)
  .site-menu
    padding 30px 0px
    site a
      text-align center
  .nav-icon 
    display block
    position relative
    z-index 1001
  .menu-backdrop
    position fixed
    top 0
    left 0
    right 0
    bottom 0
    background rgba(0, 0, 0, 0.5)
    z-index 998
    opacity 0
    visibility hidden
    transition opacity 0.3s ease, visibility 0.3s ease
    &.show
      opacity 1
      visibility visible
  .slide-menu
    background vs-white
    pointer-events auto
    width 320px
    max-width 85vw
    height 100vh
    transition transform 0.35s cubic-bezier(0.4, 0, 0.2, 1)
    position fixed
    right 0
    top 0
    transform translateX(100%)
    z-index 999
    overflow-y auto
    overflow-x hidden
    padding 90px 0px 30px 0px
    box-shadow -4px 0 20px rgba(0, 0, 0, 0.15)
    -webkit-overflow-scrolling touch
    &.menushow 
      display flex !important
      transform translateX(0)
    sites
      flex-direction column
      width 100%
      padding-bottom 20px
      site 
        justify-content flex-start
        border-bottom 1px solid #f0f0f0
        > a 
          display block
          font-size 1.8rem
          text-align left
          padding 18px 24px
          font-weight 400
          position relative
          transition background 0.2s ease, color 0.2s ease
          -webkit-tap-highlight-color transparent
          &:after
            content ''
            position absolute
            right 24px
            top 50%
            transform translateY(-50%) rotate(-45deg)
            width 8px
            height 8px
            border-right 2px solid #999
            border-bottom 2px solid #999
            transition transform 0.3s ease, border-color 0.2s ease
          &.selected
            color vs-orange
            background rgba(241, 91, 37, 0.08)
          &:active
            background rgba(0, 0, 0, 0.05)
        &.submenu-open
          > a
            color vs-orange
            background rgba(241, 91, 37, 0.05)
            &:after
              transform translateY(-50%) rotate(-135deg)
              border-color vs-orange
          pages
            display flex
            max-height 1000px
            opacity 1
            z-index 2
            top 70px
            left 20px
            padding 0px
        pages 
          display flex
          flex-direction column
          flex-wrap wrap
          max-height 0
          opacity 0
          overflow hidden
          transition max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease
          background #f8f8f8
          a 
            font-size 1.7rem
            padding 14px 24px 14px 40px
            display block
            width 100%
            text-align left
            font-weight 400
            color #303030
            background white
            transition background 0.2s ease, color 0.2s ease
            -webkit-tap-highlight-color transparent
            border-bottom 1px solid #f0f0f0
            
            &:last-child
              border-bottom none
            
            &.selected
              color vs-orange
              background rgba(241, 91, 37, 0.08)
              font-weight 500
            
            &:active
              background rgba(0, 0, 0, 0.05)

@media screen and (max-width:576px)
  .menu-col
    .vs-logo
      max-width 160px